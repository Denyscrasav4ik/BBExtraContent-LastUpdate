    {
      "key": "BBTimes_Settings_Env_Outside_Name",
      "value": "Disable The Outside"
    },
    {
      "key": "BBTimes_Settings_Env_Outside_Desc",
      "value": "Setting this \"true\" will completely disable the outside seen in-game.\nThis should slightly increase performance\n<color=red>BUT will also change the seed layouts in the game."
    },
    {
      "key": "BBTimes_Settings_Env_BigRooms_Name",
      "value": "Enable Big Rooms"
    },
    {
      "key": "BBTimes_Settings_Env_BigRooms_Desc",
      "value": "Setting this \"true\" will add the rest of the layouts Times also comes with.\n<color=red>WARNING: These layouts completely unbalance the game,\nmaking it a lot harder than the usual."
    },
    {
      "key": "BBTimes_Settings_Env_Escape_Name",
      "value": "Disable Schoolhouse Escape"
    },
    {
      "key": "BBTimes_Settings_Env_Escape_Desc",
      "value": "Setting this to \"true\" will entirely disable the schoolhouse escape sequence."
    },
    {
      "key": "BBTimes_Settings_Misc_Youtuber_Name",
      "value": "Enable Youtuber Mode"
    },
    {
      "key": "BBTimes_Settings_Misc_Youtuber_Desc",
      "value": "Wanna get some exclusive content easily? Set this to \"true\"\nand *everything* will have the weight of 9999."
    },
    {
      "key": "BBTimes_Settings_Misc_Replacements_Name",
      "value": "Disable Replacement Feature"
    },
    {
      "key": "BBTimes_Settings_Misc_Replacements_Desc",
      "value": "Setting this to \"true\" will allow replacement npcs to spawn as normal npcs instead,\nmaking the game considerably harder in some ways."
    },
    {
      "key": "BBTimes_Settings_Misc_Arcade_Name",
      "value": "Disable Arcade Renovations Support"
    },
    {
      "key": "BBTimes_Settings_Misc_Arcade_Desc",
      "value": "Setting this to \"true\" disable any checks for arcade rennovations.\nThis can be useful for RNG Floors, if you're having any issues."
    },
    {
      "key": "BBTimes_Settings_Misc_Cutscene_Name",
      "value": "Disable The Final Cutscene"
    },
    {
      "key": "BBTimes_Settings_Misc_Cutscene_Desc",
      "value": "If True, the cutscene played at the end of the game will be completely disabled."
    },
    {
      "key": "BBTimes_Settings_Misc_Legacy_Name",
      "value": "Enable Unbalanced Legacy Mode"
    },
    {
      "key": "BBTimes_Settings_Misc_Legacy_Desc",
      "value": "If True, the old Times' floor changes will be brought up back\nand make the game considerably unbalanced."
    },
    {
      "key": "BBTimes_Settings_Misc_Secrets_Name",
      "value": "Force Enable Secret Objects"
    },
    {
      "key": "BBTimes_Settings_Misc_Secrets_Desc",
      "value": "If True, the objects from the Secret Ending will added to the Level Studio,\nregardless of whether you unlocked them or not\n<color=red>(Requires restart)."
    },
